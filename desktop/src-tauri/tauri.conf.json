{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis",
  "version": "0.8.0",
  "identifier": "local.jarvis.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Jarvis",
        "width": 1280,
        "height": 780,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Jarvis esta escuchando"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "../scripts/jarvis-api-sidecar"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}
